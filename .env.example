# Copy to .env (or set in Replit Secrets) and fill in real values.

# Required
SESSION_SECRET=change-me-to-a-long-random-string
BASE_URL=http://localhost:3000

# Email (Gmail SMTP — uses an App Password, not the account password)
SMTP_USER=heath.blake3@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM="HAB Academy <heath.blake3@gmail.com>"

# Heath's super-admin account — seeded on first boot
ADMIN_EMAIL=heath@revenuenowinc.com
ADMIN_NAME=Heath Blake

# Optional
PORT=3000
NODE_ENV=development

# Optional: where SQLite files live (default: ./data). Useful if the repo dir is on a network mount.
# DATA_DIR=/absolute/path/to/data
