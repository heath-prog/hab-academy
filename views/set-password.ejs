<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= mode === 'bootstrap' ? 'Bootstrap' : 'Accept Invite' %> · HAB Academy</title>
<link rel="stylesheet" href="/style.css">
</head>
<body class="auth-wrap">
<div class="auth-card">
  <div class="brand-stack">
    <div class="shield">HAB</div>
    <div class="name">HAB Academy</div>
    <div class="sub"><%= mode === 'bootstrap' ? 'BOOTSTRAP · SUPER ADMIN' : 'SET YOUR PASSWORD' %></div>
  </div>

  <% if (error) { %><div class="alert error"><%= error %></div><% } %>

  <% if (mode === 'invite') { %>
    <p style="font-size: 14px;">Invitation for <strong><%= email %></strong> to join <strong><%= shopName %></strong> as <strong><%= role %></strong>.</p>
  <% } else { %>
    <p style="font-size: 14px;">Setting initial password for <strong><%= email %></strong>.</p>
  <% } %>

  <form method="post" action="<%= mode === 'bootstrap' ? '/bootstrap' : '/invite/' + token %>" class="stack">
    <div>
      <label for="name">Your Name</label>
      <input type="text" name="name" id="name" required autocomplete="name" autofocus>
    </div>
    <div>
      <label for="password">Password <span style="font-weight: 400; opacity: 0.7;">(min 8 chars)</span></label>
      <input type="password" name="password" id="password" required minlength="8" autocomplete="new-password">
    </div>
    <div>
      <label for="confirm">Confirm Password</label>
      <input type="password" name="confirm" id="confirm" required minlength="8" autocomplete="new-password">
    </div>
    <button type="submit" class="primary">Set Password &amp; Continue</button>
  </form>

  <div class="tagline">Do what's Right · Do what's Fair · Do Your Best.</div>
</div>
</body>
</html>
